@inbook{Fichtner1992,
 abstract = {Modern semiconductor manufacturing technology permits the integration of power integrated circuits with per-chip component densities reaching into the millions. This high-density capability, however, will only be utilized if the design costs can be limited to reasonable levels. Widely accepted for VLSI projects, the use of computer-aided design (CAD) tools has recently become a standard procedure in the development of power technologies and the design of new device structures and circuits. This paper attempts to give an overview of the status quo of CAD tools in power IC design, especially the use of simulation tools and computer- aided layout techniques. We illustrate the possibilities of these tools with examples from a recent MCT design effort.},
 address = {Boston, MA},
 author = {Fichtner, W.
and Bürgler, J.
and Dettmer, H.
and Hitschfeld, N.
and Kells, K.
and Lendenmann, H.
and Müller, S.
and Westermann, M.},
 booktitle = {Power Semiconductor Devices and Circuits},
 doi = {10.1007/978-1-4615-3322-1_6},
 editor = {Jaecklin, André A.},
 isbn = {978-1-4615-3322-1},
 pages = {139--160},
 publisher = {Springer US},
 title = {The Use of Cad Tools in Power Device Optimization},
 url = {https://doi.org/10.1007/978-1-4615-3322-1_6},
 year = {1992}
}
