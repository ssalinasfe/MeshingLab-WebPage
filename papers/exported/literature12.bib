@inbook{Fichtner1992,
	abstract = {Modern semiconductor manufacturing technology permits the integration of power integrated circuits with per-chip component densities reaching into the millions. This high-density capability, however, will only be utilized if the design costs can be limited to reasonable levels. Widely accepted for VLSI projects, the use of computer-aided design (CAD) tools has recently become a standard procedure in the development of power technologies and the design of new device structures and circuits. This paper attempts to give an overview of the status quo of CAD tools in power IC design, especially the use of simulation tools and computer- aided layout techniques. We illustrate the possibilities of these tools with examples from a recent MCT design effort.},
	address = {Boston, MA},
	author = {Fichtner, W.
and B{\"u}rgler, J.
and Dettmer, H.
and Hitschfeld, N.
and Kells, K.
and Lendenmann, H.
and M{\"u}ller, S.
and Westermann, M.},
	booktitle = {Power Semiconductor Devices and Circuits},
	doi = {10.1007/978-1-4615-3322-1_6},
	editor = {Jaecklin, Andr{\'e} A.},
	isbn = {978-1-4615-3322-1},
	pages = {139--160},
	publisher = {Springer US},
	title = {The Use of Cad Tools in Power Device Optimization},
	url = {https://doi.org/10.1007/978-1-4615-3322-1_6},
	year = {1992},
}

@inbook{Hitschfeld1997,
	abstract = {This paper discusses several aspects of modified octrees that can be generalized in order to obtain solid representations using less primitive elements than the traditional modified octree. The aspects under study include the use of elements of different type as internal nodes, a general refinement approach and cuboids, pyramids, prisms and tetrahedra as final elements. These concepts can be applied to the generation of mixed elements meshes for different applications. In particular, the new ideas are presented here for the generation of mixed element meshes that satisfy Delaunay condition. Examples are given to compare a new implementation with previous approaches.},
	address = {Berlin, Heidelberg},
	author = {Hitschfeld, N.},
	booktitle = {Geometric Modeling: Theory and Practice: The State of the Art},
	doi = {10.1007/978-3-642-60607-6_17},
	editor = {Strasser, Wolfgang
and Klein, Reinhard
and Rau, Ren{\'e}},
	isbn = {978-3-642-60607-6},
	pages = {260--272},
	publisher = {Springer Berlin Heidelberg},
	title = {Generalization of Modified Octrees for Geometric Modeling},
	url = {https://doi.org/10.1007/978-3-642-60607-6_17},
	year = {1997},
}
